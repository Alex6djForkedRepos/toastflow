{
  "name": "toastflow-core",
  "author": "adrianjanocko",
  "license": "MIT",
  "homepage": "https://toastflow.top/",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianjanocko/toastflow.git",
    "directory": "packages/core"
  },
  "version": "1.2.2-beta.4",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --clean --format cjs,esm --sourcemap && tsc -p tsconfig.build.json --emitDeclarationOnly && node ./scripts/post-build.cjs",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
