NUXT_PUBLIC_SEASONAL_MODE=off
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
NUXT_DEVTOOLS=false

# Optional Docus assistant auth. Server-only, do not expose as NUXT_PUBLIC.
AI_GATEWAY_API_KEY=
NUXT_DOCUS_ASSISTANT_MODEL=google/gemini-3-flash
# Optional override when Nuxt auto-selects a different local dev port.
NUXT_DOCUS_DEV_PORT=
# Optional full MCP URL override.
NUXT_DOCUS_MCP_SERVER=

# Optional Giscus integration for the playground feedback modal.
NUXT_PUBLIC_GISCUS_REPO=
NUXT_PUBLIC_GISCUS_REPO_ID=
NUXT_PUBLIC_GISCUS_CATEGORY=
NUXT_PUBLIC_GISCUS_CATEGORY_ID=
NUXT_PUBLIC_GISCUS_MAPPING=pathname
NUXT_PUBLIC_GISCUS_THEME=light
NUXT_PUBLIC_GISCUS_THEME_LIGHT=light
NUXT_PUBLIC_GISCUS_THEME_DARK=dark_dimmed
NUXT_PUBLIC_GISCUS_STRICT=0
