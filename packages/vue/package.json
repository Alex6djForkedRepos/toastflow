{
  "name": "vue-toastflow",
  "author": "adrianjanocko",
  "description": "Framework-agnostic toast engine with a Vue 3 renderer. Typed core, smooth stack animations, CSS-first theming, and full control over layout and behavior.",
  "keywords": [
    "notifications",
    "typescript",
    "vue",
    "toastr",
    "toast",
    "notification",
    "toast-notifications",
    "toaster",
    "toastify"
  ],
  "license": "MIT",
  "homepage": "https://toastflow.top/",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianjanocko/toastflow.git",
    "directory": "packages/vue"
  },
  "version": "1.2.0-beta.6",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/toastflow.es.js",
  "module": "./dist/toastflow.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/toastflow.es.js"
    },
    "./styles.css": "./dist/vue-toastflow.css",
    "./src/styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "vite build && node ./scripts/post-build.cjs",
    "prepack": "pnpm run build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "toastflow-core": "workspace:^"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  }
}
