{
  "name": "toastflow",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "site:dev": "pnpm --filter toastflow-site dev",
    "site:build": "pnpm --filter toastflow-site build",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "packageManager": "pnpm@9.12.3",
  "devDependencies": {
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "~10.9.2",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
